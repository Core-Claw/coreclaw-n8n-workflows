      "id": "search-scrapers",
      "name": "Search CoreClaw Scrapers",
      "type": "n8n-nodes-coreclaw.coreClaw",
      "typeVersion": 1,
      "position": [
        -900,
        120
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "notesInFlow": true,
      "notes": "Select your own CoreClaw API credential after importing this workflow."
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const candidates = $input.all().map((item) => item.json).filter(Boolean);\nconst input = $node[\"Lead Search Input\"].json;\n\nconst targetSlug = String(input.target_scraper_slug || \"\").trim();\nconst targetTitle = String(input.target_scraper_title || \"Google Map Details By Keyword\").trim().toLowerCase();\n\nconst selected = candidates.find((candidate) => String(candidate.slug || \"\") === targetSlug)\n  ?? candidates.find((candidate) => String(candidate.title || \"\").trim().toLowerCase() === targetTitle)\n  ?? candidates.find((candidate) => /google\\s*map/i.test(String(candidate.title || \"\")) && /keyword/i.test(String(candidate.title || \"\")));\n\nif (!selected?.slug) {\n  const found = candidates.map((candidate) => candidate.title || candidate.slug).filter(Boolean).slice(0, 10).join(\", \");\n  throw new Error(`Could not find the Google Maps keyword scraper from CoreClaw store search. Found: ${found || \"none\"}`);\n}\n\nreturn [{\n  json: {\n    scraper_slug: selected.slug,\n    scraper_title: selected.title || \"Google Map Details By Keyword\",\n    scraper_description: selected.description || \"\",\n    store_search_query: input.store_search_query,\n    store_candidates_checked: candidates.length,\n  },\n}];"
      },
      "id": "select-google-maps-keyword-scraper",
      "name": "Select Google Maps Keyword Scraper",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
